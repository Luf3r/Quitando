#!/usr/bin/env bash

set -Eeuo pipefail

readonly APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly IMAGE_TAG="quitando-production-verifier:tmp-$(date -u +%Y%m%d%H%M%S)-$$-${RANDOM}"

image_built=false

cleanup() {
  local primary_status=$?
  local cleanup_status=0

  trap - EXIT

  if [[ "${image_built}" == true ]]; then
    echo "Removing temporary production image tag ${IMAGE_TAG}"
    set +e
    docker image rm "${IMAGE_TAG}"
    cleanup_status=$?
    set -e

    if (( cleanup_status != 0 )); then
      echo "Failed to remove temporary production image tag ${IMAGE_TAG}" >&2

      if (( primary_status == 0 )); then
        exit "${cleanup_status}"
      fi
    fi
  fi

  exit "${primary_status}"
}

trap cleanup EXIT

cd "${APP_ROOT}"

echo "Building production image ${IMAGE_TAG}"
docker build --file Dockerfile --tag "${IMAGE_TAG}" .
image_built=true

echo "Inspecting production image ${IMAGE_TAG}"
docker run --rm --entrypoint /bin/sh "${IMAGE_TAG}" -eu -c '
  bundle check

  if [ "${BUNDLE_WITHOUT:-}" != "development:test" ]; then
    echo "Expected BUNDLE_WITHOUT=development:test, got ${BUNDLE_WITHOUT:-<unset>}" >&2
    exit 1
  fi

  ruby -e '\''
    forbidden = %w[
      rspec-rails
      factory_bot_rails
      pbt
      capybara
      selenium-webdriver
      rubocop-rails-omakase
      brakeman
      bundler-audit
      web-console
    ].freeze
    installed = Gem::Specification.to_a.map(&:name)
    present = forbidden.select { |name| installed.include?(name) }

    abort("Forbidden development/test gems are physically present: #{present.join(", ")}") unless present.empty?

    puts "Forbidden development/test gems are physically absent"
  '\''
'

echo "Production image verification passed for ${IMAGE_TAG}"
